---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { getCollection } from "astro:content";
import { normalizePostSlug } from "../../lib/slug";
import { isPostVisible } from "../../lib/postVisibility";
import { site as siteCfg } from "../../site.config";
import Giscus from "../../components/Giscus.astro";
import TableOfContents from "../../components/TableOfContents.astro";
import Series from "../../components/Series.astro";
import CategorySidebar from "../../components/CategorySidebar.astro";

export async function getStaticPaths() {
  const posts = await getCollection("posts", ({ data }) => isPostVisible(data));
  return posts.map((p) => ({ params: { slug: normalizePostSlug(p.slug) }, props: { post: p } }));
}
const { post } = Astro.props;
const rendered = await post.render();
const { Content, headings } = rendered;
const ogImage = `/og/blog/${normalizePostSlug(post.slug)}.png`;

const dateStr = post.data.date.toISOString().slice(0, 10);
const updatedStr = post.data.updated ? post.data.updated.toISOString().slice(0, 10) : null;

const siteUrl = Astro.site?.href ?? "https://clickin.github.io/";
const postUrl = new URL(`/blog/${normalizePostSlug(post.slug)}/`, siteUrl).href;

const structuredData = {
  "@context": "https://schema.org",
  "@type": "BlogPosting",
  "headline": post.data.title,
  "url": postUrl,
  "description": post.data.description ?? siteCfg.description,
  "image": new URL(ogImage, siteUrl).href,
  "datePublished": post.data.date.toISOString(),
  "dateModified": post.data.updated?.toISOString() ?? post.data.date.toISOString(),
  "author": {
    "@type": "Person",
    "name": siteCfg.author,
    "url": siteUrl
  },
  "publisher": {
    "@type": "Organization",
    "name": siteCfg.title,
    "logo": {
      "@type": "ImageObject",
      "url": new URL("/favicon.png", siteUrl).href
    }
  },
  "mainEntityOfPage": {
    "@type": "WebPage",
    "@id": postUrl
  }
};
---
<BaseLayout 
  title={post.data.title} 
  description={post.data.description} 
  ogImage={ogImage} 
  mainClass="max-w-7xl mx-auto px-4 sm:px-6"
  type="article"
  publishDate={post.data.date}
  updatedDate={post.data.updated}
  structuredData={structuredData}
>
  <!-- Mobile Category Navigation -->
  <div class="lg:hidden mb-4">
    <CategorySidebar activeCategoryPath={post.data.category.split(">").map(s => s.trim()).join("/")} />
  </div>

  <div class="flex flex-col lg:flex-row gap-8 lg:gap-12 min-w-0">
    <!-- Left Sidebar: Categories (Hidden on mobile/tablet, shown on desktop) -->
    <aside class="cat-sidebar hidden lg:block w-48 flex-shrink-0 sticky top-20 self-start">
      <CategorySidebar activeCategoryPath={post.data.category.split(">").map(s => s.trim()).join("/")} />
    </aside>

    <div class="flex-1 min-w-0 flex flex-col xl:flex-row gap-8 xl:gap-12">
      <article class="py-4 flex-1 min-w-0 w-full break-words">
        <header class="mb-8">

              <h1 class="text-3xl sm:text-4xl font-extrabold mb-4">{post.data.title}</h1>
              <div class="flex flex-wrap items-center gap-3 text-sm text-[var(--color-text-secondary)]">
                <time datetime={post.data.date.toISOString()}>{dateStr}</time>
                {updatedStr && (
                  <span class="text-[var(--color-text-secondary)]">
                    (updated {updatedStr})
                  </span>
                )}
                <span>·</span>
                <a 
                  href={`/blog/category/${post.data.category.split(">").map(s => s.trim()).join("/")}`}
                  data-pagefind-filter="category"
                  class="px-2 py-0.5 rounded-full bg-[var(--color-tag-bg)] text-[var(--color-tag-text)] text-xs font-medium no-underline hover:opacity-80 transition-opacity"
                >
                  {post.data.category}
                </a>
              </div>
    
        {post.data.tags.length > 0 && (
          <div class="flex flex-wrap gap-2 mt-3">
            {post.data.tags.map((tag: string) => (
              <a 
                href={`/blog/tag/${tag}`}
                data-pagefind-filter="tag"
                class="text-xs text-[var(--color-text-secondary)] no-underline hover:text-[var(--color-accent)] transition-colors"
              >
                #{tag}
              </a>
            ))}
          </div>
        )}
      </header>

      {post.data.series && (
        <Series series={post.data.series} currentSlug={post.slug} />
      )}

      <Content />
      <Giscus />
    </article>

    <aside class="hidden xl:block w-64 flex-shrink-0 sticky top-20 self-start">
      <TableOfContents headings={headings} />
    </aside>
  </div>
</BaseLayout>

<script>
  const COPY_ICON = `<svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="9" y="9" width="13" height="13" rx="2" ry="2"/><path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"/></svg>`;
  const CHECK_ICON = `<svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="20 6 9 17 4 12"/></svg>`;

  document.querySelectorAll("article pre").forEach((pre) => {
    const btn = document.createElement("button");
    btn.className = "copy-code-btn";
    btn.setAttribute("aria-label", "Copy code");
    btn.innerHTML = `${COPY_ICON}<span>Copy</span>`;

    btn.addEventListener("click", async () => {
      const code = pre.querySelector("code")?.textContent ?? "";
      try {
        await navigator.clipboard.writeText(code);
        btn.innerHTML = `${CHECK_ICON}<span>Copied!</span>`;
        btn.classList.add("copied");
        setTimeout(() => {
          btn.innerHTML = `${COPY_ICON}<span>Copy</span>`;
          btn.classList.remove("copied");
        }, 2000);
      } catch {
        // clipboard access denied — silently ignore
      }
    });

    pre.appendChild(btn);
  });
</script>

<script>
  // ── Footnote popover ──────────────────────────────────────────────────────
  (function () {
    const refs = document.querySelectorAll("a[data-footnote-ref]");
    if (!refs.length) return;

    const popover = document.createElement("div");
    popover.id = "fn-popover";
    popover.setAttribute("role", "tooltip");
    popover.setAttribute("aria-hidden", "true");
    document.body.appendChild(popover);

    let hideTimer: ReturnType<typeof setTimeout> | null = null;
    let activeTouchRef: Element | null = null;

    function getFootnoteHTML(href: string): string | null {
      const li = document.getElementById(href.slice(1));
      if (!li) return null;
      const clone = li.cloneNode(true) as Element;
      clone.querySelectorAll("[data-footnote-backref]").forEach((el) => el.remove());
      return (clone as HTMLElement).innerHTML.trim();
    }

    function show(anchor: Element) {
      if (hideTimer) clearTimeout(hideTimer), (hideTimer = null);

      const html = getFootnoteHTML(anchor.getAttribute("href") ?? "");
      if (!html) return;

      popover.innerHTML = html;
      popover.style.maxWidth = Math.min(320, window.innerWidth - 24) + "px";
      popover.style.top = "-9999px";
      popover.style.left = "-9999px";
      popover.setAttribute("aria-hidden", "false");

      requestAnimationFrame(() => {
        const r = anchor.getBoundingClientRect();
        const ph = popover.offsetHeight;
        const pw = popover.offsetWidth;
        const gap = 8;

        const topAbove = r.top - ph - gap;
        const top = topAbove >= 8 ? topAbove : r.bottom + gap;
        let left = r.left + r.width / 2 - pw / 2;
        left = Math.max(12, Math.min(left, window.innerWidth - pw - 12));

        popover.style.top = `${top}px`;
        popover.style.left = `${left}px`;
        popover.classList.add("fn-popover--open");
      });
    }

    function hide() {
      if (hideTimer) clearTimeout(hideTimer), (hideTimer = null);
      popover.classList.remove("fn-popover--open");
      popover.setAttribute("aria-hidden", "true");
      activeTouchRef = null;
    }

    function scheduleHide() {
      hideTimer = setTimeout(hide, 200);
    }

    refs.forEach((anchor) => {
      const sup = anchor.parentElement!;

      // Desktop: hover
      sup.addEventListener("mouseenter", () => show(anchor));
      sup.addEventListener("mouseleave", scheduleHide);

      // Mobile: first touch shows popover, second touch navigates
      sup.addEventListener(
        "touchstart",
        (e) => {
          if (activeTouchRef === anchor) {
            activeTouchRef = null;
            hide();
            return;
          }
          e.preventDefault();
          activeTouchRef = anchor;
          show(anchor);
        },
        { passive: false }
      );
    });

    popover.addEventListener("mouseenter", () => {
      if (hideTimer) clearTimeout(hideTimer), (hideTimer = null);
    });
    popover.addEventListener("mouseleave", scheduleHide);

    // Tap outside to dismiss
    document.addEventListener("touchstart", (e) => {
      if (
        activeTouchRef &&
        !(e.target as Element).closest("a[data-footnote-ref]") &&
        !popover.contains(e.target as Node)
      ) {
        hide();
      }
    });
  })();
</script>
