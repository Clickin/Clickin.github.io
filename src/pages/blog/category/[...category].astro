---
import BaseLayout from "../../../layouts/BaseLayout.astro";
import { getCollection } from "astro:content";
import PostPreview from "../../../components/PostPreview.astro";
import CategorySidebar from "../../../components/CategorySidebar.astro";
import { isPostVisible } from "../../../lib/postVisibility";

export async function getStaticPaths() {
  const posts = await getCollection("posts", ({ data }) => isPostVisible(data));
  
  const categoryPaths = new Set<string>();
  posts.forEach(post => {
    const parts = post.data.category.split(">").map(s => s.trim());
    let currentPath = "";
    parts.forEach((part, index) => {
      currentPath = index === 0 ? part : `${currentPath}/${part}`;
      categoryPaths.add(currentPath);
    });
  });

  return Array.from(categoryPaths).map((fullPath) => {
    // URL path used in parameters: "Java/Spring"
    // Display name: "Spring" (last part)
    const parts = fullPath.split("/");
    const displayName = parts[parts.length - 1];
    
    const filteredPosts = posts.filter(post => {
      const postCategoryPath = post.data.category.split(">").map(s => s.trim()).join("/");
      // 부모 카테고리 클릭 시 하위 카테고리 글도 포함하려면 startsWith 사용
      return postCategoryPath === fullPath || postCategoryPath.startsWith(`${fullPath}/`);
    }).sort((a, b) => {
      const dateDiff = (b.data.updated ?? b.data.date).valueOf() - (a.data.updated ?? a.data.date).valueOf();
      if (dateDiff !== 0) return dateDiff;
      return (b.data.order ?? 0) - (a.data.order ?? 0);
    });

    return {
      params: { category: fullPath },
      props: {
        categoryName: displayName,
        fullPath,
        posts: filteredPosts,
      },
    };
  });
}

const { categoryName, fullPath, posts } = Astro.props;
---

<BaseLayout title={`Category: ${categoryName}`} description={`Posts in category ${categoryName}`} mainClass="max-w-5xl mx-auto px-4 sm:px-6">
  <div class="mb-8">
    <h1 class="text-3xl sm:text-4xl font-extrabold mb-2 capitalize">{categoryName}</h1>
    <p class="text-[var(--color-text-secondary)]">{posts.length} posts found in this category</p>
  </div>

  <div class="flex flex-col lg:flex-row gap-8 lg:gap-12">
    <aside class="w-full lg:w-48 flex-shrink-0 lg:sticky lg:top-20 lg:self-start">
      <CategorySidebar activeCategoryPath={fullPath} />
    </aside>
    
    <div class="flex-1 min-w-0 flex flex-col gap-4">
      {posts.map((p) => (
        <PostPreview post={p} />
      ))}
    </div>
  </div>
</BaseLayout>
